{
    "name": "senren-talk",
    "private": true,
    "version": "0.1.0",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "concurrently --raw -k \"tsx watch src/server/index.ts\" \"vite\"",
        "dev:server": "tsx watch src/server/index.ts",
        "dev:client": "vite",
        "build": "tsc --noEmit && vite build",
        "start": "tsx src/server/index.ts",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "test": "vitest run",
        "test:watch": "vitest",
        "index:dialogues": "tsx scripts/build-dialogue-index.ts",
        "benchmark": "npx tsx benchmark/agent-benchmark.ts"
    },
    "dependencies": {
        "@elastic/elasticsearch": "9.4.2",
        "@langchain/core": "1.1.48",
        "@langchain/langgraph": "1.3.6",
        "better-sqlite3": "12.10.0",
        "concurrently": "^10.0.3",
        "dotenv": "17.4.2",
        "express": "5.2.1",
        "framer-motion": "^12.40.0",
        "langsmith": "^0.7.5",
        "lucide-react": "^1.17.0",
        "multer": "^2.1.1",
        "openai": "6.42.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "uuid": "14.0.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "latest",
        "@testing-library/react": "latest",
        "@types/better-sqlite3": "latest",
        "@types/express": "latest",
        "@types/multer": "^2.1.0",
        "@types/node": "latest",
        "@types/react": "^18.2.64",
        "@types/react-dom": "^18.2.21",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^7.1.1",
        "@typescript-eslint/parser": "^7.1.1",
        "@vitejs/plugin-react": "^6.0.2",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "jsdom": "29.1.1",
        "pptxgenjs": "^4.0.1",
        "tsx": "4.22.4",
        "typescript": "^5.2.2",
        "vite": "^8.0.16",
        "vitest": "4.1.8"
    }
}
